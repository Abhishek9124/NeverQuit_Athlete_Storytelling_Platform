# NVIDIA OpenAI-compatible API
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_STORY_MODEL=openai/gpt-oss-20b
NVIDIA_MIN_INTERVAL_S=0.5
NVIDIA_MAX_CONCURRENT=1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Webflow
WEBFLOW_API_KEY=your-webflow-token
WEBFLOW_COLLECTION_ID=your-cms-collection-id
WEBFLOW_SITE_ID=your-site-id

# Mailchimp (optional — for newsletter campaigns)
MAILCHIMP_API_KEY=your-mailchimp-key
MAILCHIMP_AUDIENCE_ID=your-list-id
MAILCHIMP_SERVER_PREFIX=us1

# SMTP (used when Mailchimp is not set — sends welcome emails + broadcasts)
# For Gmail: enable 2FA, then create an App Password and paste it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=NeverQuit <you@gmail.com>
SITE_URL=https://neverquit.in

# Notion
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=your-database-id

# Social
TWITTER_BEARER_TOKEN=your-token
BUFFER_ACCESS_TOKEN=your-token

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-secret

# Pipeline config
DAILY_STORY_QUOTA=1
MIN_CONFIDENCE_SCORE=75
AUTO_APPROVE_THRESHOLD=90

# Web app
ADMIN_TOKEN=change-this-to-a-long-random-string
FLASK_SECRET=change-this-too
PORT=5000
